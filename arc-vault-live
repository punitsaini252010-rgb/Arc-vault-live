<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ARC | THE VAULT</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400&family=Montserrat:wght@300;500;800;900&display=swap" rel="stylesheet">
    
    <style>
        :root {
            var-bg-deep: #2c1e12;
            var-bg-mid: #4b3621;
            var-bg-light: #5C4033;
            var-gold: #D4AF37;
            var-cyan: #00FFFF;
            var-red: #FF003C;
            var-green: #004225;
        }

        body {
            margin: 0;
            overflow: hidden;
            background: #2c1e12;
            background: radial-gradient(circle at top right, #5C4033, #2c1e12);
            color: #FFFFFF;
            font-family: 'Montserrat', sans-serif;
            -webkit-font-smoothing: antialiased;
        }

        .old-money-heading {
            font-family: 'Playfair Display', serif;
            background: linear-gradient(135deg, #BF953F, #FCF6BA, #b38728, #FBF5B7, #AA771C);
            -webkit-background-clip: text;
            color: transparent;
            text-shadow: 0px 4px 15px rgba(212, 175, 55, 0.2);
        }

        .gold-border {
            border: 1px solid #AA771C;
            box-shadow: 0 0 10px rgba(191, 149, 63, 0.3);
        }

        .levitate {
            animation: float 4s ease-in-out infinite;
        }
        @keyframes float {
            0% { transform: translateY(0px) rotateX(0deg); }
            50% { transform: translateY(-10px) rotateX(2deg); }
            100% { transform: translateY(0px) rotateX(0deg); }
        }

        .fly-in {
            opacity: 0;
            transform: translateY(40px);
            transition: all 0.8s cubic-bezier(0.25, 1, 0.5, 1);
        }
        .fly-in.active {
            opacity: 1;
            transform: translateY(0);
        }

        .click-ripple {
            position: fixed;
            border-radius: 50%;
            border: 2px solid #00FFFF;
            box-shadow: 0 0 20px #00FFFF;
            pointer-events: none;
            transform: translate(-50%, -50%) scale(0);
            animation: ripple 0.6s ease-out forwards;
            z-index: 9999;
        }
        @keyframes ripple {
            0% { transform: translate(-50%, -50%) scale(0); opacity: 1; }
            100% { transform: translate(-50%, -50%) scale(3); opacity: 0; }
        }

        .sidebar-panel {
            background: rgba(44, 30, 18, 0.95);
            backdrop-filter: blur(10px);
            border-right: 1px solid rgba(191, 149, 63, 0.2);
        }

        .nav-item {
            transition: all 0.3s ease;
            border-left: 3px solid transparent;
            cursor: pointer;
        }
        .nav-item.active {
            background: linear-gradient(90deg, rgba(191,149,63,0.1) 0%, transparent 100%);
            border-left: 3px solid #D4AF37;
            color: #D4AF37;
        }
        .nav-item:hover:not(.locked) {
            background: rgba(255,255,255,0.05);
            transform: translateX(5px);
        }
        .locked {
            opacity: 0.5;
            cursor: not-allowed;
            color: #888;
        }

        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: #2c1e12; }
        ::-webkit-scrollbar-thumb { background: #AA771C; border-radius: 10px; }
    </style>
</head>
<body class="flex h-screen w-screen">

    <script>
        document.addEventListener('click', function(e) {
            let ripple = document.createElement('div');
            ripple.className = 'click-ripple';
            ripple.style.left = e.clientX + 'px';
            ripple.style.top = e.clientY + 'px';
            document.body.appendChild(ripple);
            setTimeout(() => ripple.remove(), 600);
        });
    </script>

    <button onclick="toggleSidebar()" class="md:hidden fixed top-4 left-4 z-50 gold-border bg-[#2c1e12] p-3 rounded shadow-lg">
        <svg class="w-6 h-6 text-[#D4AF37]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path></svg>
    </button>

    <div id="sidebar" class="sidebar-panel w-72 h-full flex-shrink-0 flex flex-col absolute md:relative z-40 transform -translate-x-full md:translate-x-0 transition-transform duration-300">
        <div class="p-8 border-b border-[#AA771C]/20">
            <h2 class="old-money-heading text-4xl levitate cursor-default">ARC</h2>
            <p class="text-[10px] text-gray-400 uppercase tracking-widest mt-2 font-bold">Instant Liquidity Matrix</p>
        </div>
        <div class="flex-1 overflow-y-auto p-4 space-y-6" id="nav-container">
            </div>
    </div>

    <div class="flex-1 flex flex-col relative h-full">
        <div class="h-16 md:h-20 border-b border-[#AA771C]/20 bg-[#2c1e12]/80 backdrop-blur flex items-center justify-between px-6 md:px-12 z-20 shadow-xl">
            <div class="hidden md:block">
                <span class="text-xs text-gray-400 font-mono uppercase tracking-widest">Status: <span class="text-[#004225] font-bold">Live & Connected</span></span>
            </div>
            
            <audio id="arc-audio" src=""></audio>
            <button id="audio-btn" onclick="toggleAudio()" class="gold-border px-4 py-2 md:px-6 md:py-3 text-[10px] md:text-xs font-black uppercase tracking-widest hover:bg-[#AA771C] hover:text-black transition-all ml-auto">
                🔊 [ INITIALIZE AUDIO ]
            </button>
        </div>

        <div id="scroll-canvas" class="flex-1 overflow-y-auto p-6 md:p-16 scroll-smooth relative z-10 pt-24 md:pt-16">
            <div class="max-w-4xl mx-auto pb-32" id="lesson-content">
                </div>
        </div>
        
        <div class="absolute bottom-0 left-1/2 transform -translate-x-1/2 w-full h-96 bg-gradient-to-t from-[#00FFFF]/5 to-transparent pointer-events-none z-0"></div>
    </div>

    <script>
        const arcData = {
            models: [
                {
                    id: "model-1",
                    title: "MODEL 01: THE SAAS TOLL BOOTH",
                    description: "High-Ticket Middleman Protocol",
                    isLocked: false,
                    parts: [
                        {
                            id: "m1-p1",
                            title: "PART 1: THE SLAUGHTER",
                            audio: "https://www.soundhelix.com/examples/mp3/SoundHelix-Song-1.mp3",
                            content: '<h1 class="old-money-heading text-4xl md:text-6xl mb-8 fly-in">THE MIDDLEMAN SLAUGHTER</h1><p class="text-lg md:text-xl leading-loose mb-8 fly-in text-gray-200">Listen to me motherfucker. You want to get rich? You need instant fucking liquidity. Not in ten years. Not after a college degree. NOW.</p><p class="text-lg md:text-xl leading-loose mb-8 fly-in text-gray-200">Creating your own product is a suicide mission. Inventing software takes millions of dollars and a team of nerds. If it breaks, you lose everything. We bypass that slaughter entirely. You do not build the road. You assemble the toll booth.</p><div class="my-10 p-8 border border-[#FF003C] bg-red-900/10 rounded-lg fly-in levitate shadow-[0_0_20px_rgba(255,0,60,0.15)]"><h3 class="text-[#FF003C] font-black text-xl mb-4 tracking-widest uppercase">⚠️ THE MANIPULATION TACTIC</h3><p class="font-mono text-sm leading-relaxed text-gray-300">Salesmen beg. Operators prescribe. If you want an agency owner to buy a $5,000 CRM through your link, you don\'t talk about cool features. You look at his business and say: <br><br><span class="text-white font-bold">"Your team is losing $4,000 a month in manual data entry. This AI system replaces your assistant for $500 a month."</span><br><br>He doesn\'t look at the cost. He looks at the $3,500 he just saved. You drop the link, and you walk away. Let him chase you.</p></div>'
                        },
                        {
                            id: "m1-p2",
                            title: "PART 2: THE 60-DAY COOKIE",
                            audio: "",
                            content: '<h1 class="old-money-heading text-4xl md:text-6xl mb-8 fly-in">THE 60-DAY COOKIE TRAP</h1><p class="text-lg md:text-xl leading-loose mb-8 fly-in text-gray-200">This is how you get paid while you sleep. High-ticket buyers do not impulse buy. A CEO takes a week to think about a massive expense.</p><p class="text-lg md:text-xl leading-loose mb-8 fly-in text-gray-200">When you give them your affiliate link, it drops an invisible tracking cookie in their browser. It stays there for 60 to 90 days! Even if they close the tab, talk to their board, and come back directly to the site a month later... the code remembers. The code wires you the cash.</p><div class="my-10 p-8 border border-[#00FFFF] fly-in" style="background: rgba(0,0,0,0.4); backdrop-filter: blur(5px);"><h2 class="text-2xl font-black text-[#00FFFF] mb-6 uppercase tracking-widest">⚙️ THE SETUP PROTOCOL</h2><ul class="list-none space-y-4 text-sm font-mono text-gray-300"><li class="flex items-start"><span class="text-[#00FFFF] mr-4 font-bold">1.</span> Go to PartnerStack.com or Impact.com.</li><li class="flex items-start"><span class="text-[#00FFFF] mr-4 font-bold">2.</span> Apply for B2B Enterprise CRM programs offering 40%+ recurring commissions.</li><li class="flex items-start"><span class="text-[#00FFFF] mr-4 font-bold">3.</span> When asked how you promote, do not say "TikTok." Say: "I run a targeted B2B content funnel for digital marketing agencies." You will be approved instantly.</li></ul></div>'
                        }
                    ]
                },
                {
                    id: "model-2",
                    title: "MODEL 02: B2B LEAD ARBITRAGE",
                    description: "The Ghost Agency",
                    isLocked: false,
                    parts: [
                        {
                            id: "m2-p1",
                            title: "PART 1: THE BLEEDING NECK",
                            audio: "",
                            content: '<h1 class="old-money-heading text-4xl md:text-6xl mb-8 fly-in">THE BLEEDING NECK</h1><p class="text-lg md:text-xl leading-loose mb-8 fly-in text-gray-200">Every single offline business on earth wants one fucking thing: More paying clients.</p><p class="text-lg md:text-xl leading-loose mb-8 fly-in text-gray-200">If you can bring a local roofing company or a solar business a list of people who are begging to buy, they will write you a blank check. You do not need an office. You do not need employees. You are a Ghost Agency.</p><div class="my-10 p-8 border border-[#004225] bg-green-900/10 rounded-lg fly-in levitate shadow-[0_0_20px_rgba(0,66,37,0.3)]"><h3 class="text-[#FFD700] font-black text-xl mb-4 tracking-widest uppercase">💡 THE BIG DREAM SCALING</h3><p class="font-mono text-sm leading-relaxed text-gray-300">You close one solar company. You send them 10 leads a week at $100 each. That is $1,000 a week pure profit from ONE client. Get five clients. You are now making $5,000 a week. Park that cash in Delta Exchange, trade AIOTUSD.P futures with precision, and watch your capital compound into a multi-million dollar fortress.</p></div>'
                        },
                        {
                            id: "m2-p2",
                            title: "PART 2: SCRAPE & STRIKE",
                            audio: "",
                            content: '<h1 class="old-money-heading text-4xl md:text-6xl mb-8 fly-in">SCRAPE & STRIKE</h1><p class="text-lg md:text-xl leading-loose mb-8 fly-in text-gray-200">How do you get the leads? You scrape them. Use tools like Apollo.io or D7 Lead Finder. You find businesses spending money on Google Ads but running shit websites.</p><p class="text-lg md:text-xl leading-loose mb-8 fly-in text-gray-200">You don\'t sell them marketing. You sell them the END RESULT. Arbitrage the attention. Buy cheap clicks on Facebook, capture the lead info, and flip it to the local business owner for a 500% markup.</p><div class="my-10 p-8 border border-[#D4AF37] fly-in" style="background: rgba(0,0,0,0.4); backdrop-filter: blur(5px);"><h2 class="text-xl font-black text-[#D4AF37] mb-6 uppercase tracking-widest">✉️ THE LETHAL COLD EMAIL SCRIPT</h2><p class="font-mono text-sm text-gray-300 italic">"Hey [Name],<br><br>I have 5 homeowners in [City] looking to get solar installed this week. My usual partner is completely booked up. Can you handle the volume?<br><br>Reply YES and I\'ll send you their phone numbers right now."</p><p class="mt-4 text-xs text-[#00FFFF] uppercase font-bold tracking-widest">Notice: They will reply. Because you aren\'t selling a service, you are handing them free money.</p></div>'
                        }
                    ]
                },
                {
                    id: "model-3",
                    title: "MODEL 03: THE DIGITAL SHIELD",
                    description: "Low-Ticket Cashflow",
                    isLocked: false,
                    parts: [
                        {
                            id: "m3-p1",
                            title: "PART 1: THE $47 WALL",
                            audio: "",
                            content: '<h1 class="old-money-heading text-4xl md:text-6xl mb-8 fly-in">THE $47 WALL</h1><p class="text-lg md:text-xl leading-loose mb-8 fly-in text-gray-200">You cannot survive hunting big whales if you can\'t pay your fucking rent. You need a baseline. You need a shield.</p><p class="text-lg md:text-xl leading-loose mb-8 fly-in text-gray-200">You package your knowledge into a high-value PDF document. You price it at $47 or $49. You put it on Gumroad. This weeds out the broke, useless freebie-seekers! If a guy won\'t pay $47 to fix his life, he is a waste of your breath.</p><div class="my-10 p-8 border border-[#00FFFF] bg-cyan-900/10 rounded-lg fly-in shadow-[0_0_20px_rgba(0,255,255,0.1)]"><h3 class="text-[#00FFFF] font-black text-xl mb-4 tracking-widest uppercase">🏦 THE BANKING PROTOCOL</h3><p class="font-mono text-sm leading-relaxed text-gray-300">When setting up your Gumroad payout, precision is everything. If you are underage or bypassing the live face check, you must legally coordinate with whoever\'s ID you are using (like a parent). The banking details MUST perfectly match the identity documents. If your bank says Prameshwar, do not type Parmeshwar. Get paid, stack the capital, and stay off the radar.</p></div>'
                        }
                    ]
                },
                {
                    id: "model-4",
                    title: "MODEL 04: THE ESCAPE ROUTE",
                    description: "Advanced Scaling Tactics",
                    isLocked: true,
                    parts: []
                }
            ]
        };

        let currentPart = arcData.models[0].parts[0];
        let isAudioPlaying = false;
        let audioElement;
        let audioBtn;
        let scrollCanvas;

        window.onload = () => {
            audioElement = document.getElementById('arc-audio');
            audioBtn = document.getElementById('audio-btn');
            scrollCanvas = document.getElementById('scroll-canvas');
            
            renderSidebar();
            loadContent(currentPart);

            audioElement.onended = () => {
                isAudioPlaying = false;
                audioBtn.innerHTML = '🔊 [ INITIALIZE AUDIO ]';
            };
        };

        function toggleSidebar() {
            document.getElementById('sidebar').classList.toggle('-translate-x-full');
        }

        function renderSidebar() {
            const container = document.getElementById('nav-container');
            container.innerHTML = '';

            arcData.models.forEach(model => {
                const modelBlock = document.createElement('div');
                modelBlock.className = 'mb-6';
                
                let titleHtml = '<div class="text-[10px] text-[#D4AF37] uppercase tracking-widest font-black mb-1 flex items-center justify-between">' + model.title;
                if (model.isLocked) titleHtml += ' <span class="text-red-500">🔒</span>';
                titleHtml += '</div>';

                let descHtml = '<div class="text-xs text-gray-500 mb-3">' + model.description + '</div>';
                let listHtml = '<ul class="space-y-1 pl-2 border-l border-gray-800">';

                if (!model.isLocked) {
                    model.parts.forEach(part => {
                        const isActive = currentPart.id === part.id ? 'active' : '';
                        const titleLabel = part.title.split(':')[0];
                        listHtml += '<li><div onclick="selectPart(\'' + part.id + '\')" class="nav-item w-full text-left px-4 py-2 text-xs font-bold uppercase text-gray-300 ' + isActive + '">' + titleLabel + '</div></li>';
                    });
                } else {
                    listHtml += '<li><span class="nav-item locked block px-4 py-2 text-xs font-bold uppercase">Awaiting Transmission</span></li>';
                }

                listHtml += '</ul>';
                modelBlock.innerHTML = titleHtml + descHtml + listHtml;
                container.appendChild(modelBlock);
            });
        }

        function selectPart(partId) {
            arcData.models.forEach(model => {
                model.parts.forEach(part => {
                    if (part.id === partId) {
                        currentPart = part;
                        renderSidebar();
                        loadContent(currentPart);
                        if(window.innerWidth < 768) toggleSidebar(); 
                    }
                });
            });
        }

        function loadContent(part) {
            document.getElementById('lesson-content').innerHTML = part.content;
            scrollCanvas.scrollTop = 0;

            audioElement.src = part.audio || "";
            isAudioPlaying = false;
            audioElement.pause();
            audioBtn.innerHTML = '🔊 [ INITIALIZE AUDIO ]';

            setupScrollMagic();
        }

        function setupScrollMagic() {
            const elements = document.querySelectorAll('.fly-in');
            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        entry.target.classList.add('active');
                    }
                });
            }, { threshold: 0.1 });

            elements.forEach(el => observer.observe(el));
            
            setTimeout(() => {
                elements.forEach((el, index) => {
                    if(index < 2) el.classList.add('active');
                });
            }, 100);
        }

        function toggleAudio() {
            if (!audioElement.src || audioElement.src.endsWith("/")) {
                alert("Audio stream currently unavailable for this module.");
                return;
            }
            if (isAudioPlaying) {
                audioElement.pause();
                audioBtn.innerHTML = '🔊 [ INITIALIZE AUDIO ]';
            } else {
                audioElement.play().catch(e => console.log("Audio blocked."));
                audioBtn.innerHTML = '⏸ [ PAUSE DICTATION ]';
            }
            isAudioPlaying = !isAudioPlaying;
        }
    </script>
</body>
</html>

